# OutTheGC Configuration

# Base URL for share links (set to your custom domain in production)
# Default: https://outthegc.app
NEXT_PUBLIC_BASE_URL=https://outthegc.app

# Postgres database URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# OpenAI API key for Ideas tab organization
OPENAI_API_KEY=""

# Optional override for the ideas-organizing model
OPENAI_IDEAS_MODEL="gpt-4o-mini"

# Stripe billing for OutTheGC+
STRIPE_SECRET_KEY=""
STRIPE_PLUS_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
