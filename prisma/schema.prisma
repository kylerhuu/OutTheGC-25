generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id                 String            @id
  name               String
  description        String
  startDate          String
  endDate            String
  createdAt          DateTime          @default(now())
  responses          TripResponse[]
  destinationOptions TripDestination[]
}

model TripResponse {
  id                String   @id
  tripId            String
  name              String
  editCode          String
  availabilityStart String?
  availabilityEnd   String?
  destinations      String[]
  budget            String
  interests         String[]
  notes             String
  submittedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
  trip              Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TripDestination {
  id             String   @id
  tripId         String
  name           String
  normalizedName String
  createdAt      DateTime @default(now())
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@unique([tripId, normalizedName])
}
