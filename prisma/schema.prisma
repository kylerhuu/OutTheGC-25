generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id                 String            @id
  name               String
  description        String
  startDate          String
  endDate            String
  ownerTokenHash     String?
  ownerEmail         String?
  planTier           String            @default("free")
  stripeCustomerId   String?           @unique
  stripeSubscriptionId String?         @unique
  stripePriceId      String?
  stripeSubscriptionStatus String      @default("inactive")
  stripeCurrentPeriodEnd DateTime?
  createdAt          DateTime          @default(now())
  responses          TripResponse[]
  destinationOptions TripDestination[]
  interestOptions    TripInterest[]
  plan               TripPlan?
}

model TripResponse {
  id                String   @id
  tripId            String
  name              String
  editCode          String
  availabilityStart String?
  availabilityEnd   String?
  destinations      String[]
  budget            String
  interests         String[]
  notes             String
  submittedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
  unavailableRanges TripResponseUnavailableRange[]
  trip              Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TripResponseUnavailableRange {
  id         String       @id
  responseId String
  startDate  String
  endDate    String
  createdAt  DateTime     @default(now())
  response   TripResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId])
}

model TripDestination {
  id             String   @id
  tripId         String
  name           String
  normalizedName String
  createdAt      DateTime @default(now())
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@unique([tripId, normalizedName])
}

model TripInterest {
  id             String   @id
  tripId         String
  name           String
  normalizedName String
  createdAt      DateTime @default(now())
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@unique([tripId, normalizedName])
}

model TripPlan {
  id                  String           @id
  tripId              String           @unique
  finalDestination    String
  finalStartDate      String?
  finalEndDate        String?
  housingNotes        String           @default("")
  attractionNotes     String           @default("")
  foodNotes           String           @default("")
  activityNotes       String           @default("")
  dayPlanNotes        String           @default("")
  transportationNotes String
  bookingNotes        String           @default("")
  otherNotes          String           @default("")
  finalDocContent     String           @default("")
  itineraryIdeas      String           @default("")
  lodgingNotes        String           @default("")
  budgetNotes         String           @default("")
  groupNotes          String           @default("")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  trip                Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  todos               TripPlanTodo[]
}

model TripPlanTodo {
  id         String   @id
  tripPlanId String
  text       String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  plan       TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)

  @@index([tripPlanId])
}
